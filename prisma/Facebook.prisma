model FacebookAuthor {
  id               String   @id @default(cuid())
  userId           String
  pageId           String
  pageName         String?
  pageAccessToken  String
  autoPublish      Boolean  @default(true)
  tokenExpiresAt   DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User @relation(fields: [userId], references: [id], onDelete: Cascade)
  facebookPosts    FacebookPost[]

  @@index([userId])
  @@map("facebook_authors")
}

model FacebookPost {
  id                 String   @id @default(cuid())
  userId             String
  facebookAuthorId   String?
  title              String
  description        String
  hashtags           String?
  href               String?
  image              String?
  status             FacebookPostStatus @default(DRAFT)
  publishAt          DateTime?
  publishedAt        DateTime?
  facebookPostId     String?
  errorMessage       String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User @relation(fields: [userId], references: [id], onDelete: Cascade)
  facebookAuthor     FacebookAuthor? @relation(fields: [facebookAuthorId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([publishAt])
  @@index([facebookAuthorId])
  @@map("facebook_posts")
}

enum FacebookPostStatus {
  DRAFT
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
}