model File {
  id        String    @id @default(cuid())
  userId    String?
  folderId  String?
  title     String
  fileName  String
  mimeType  String
  size      Int
  provider  String
  key       String
  url       String
  category  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder Folder? @relation(fields: [folderId], references: [id])
}
