enum EmailProvider {
  GOOGLE
}

enum EmailConnectionStatus {
  CONNECTED
  DISCONNECTED
  EXPIRED
}

model EmailProviderConfig {
  id           String                @id @default(cuid())
  siteId       String                @unique @map("site_id")
  provider     EmailProvider         @default(GOOGLE)
  email        String
  name         String?
  picture      String?
  status       EmailConnectionStatus @default(CONNECTED)
  accessToken  String                @db.Text
  refreshToken String                @db.Text
  expiresAt    DateTime              @map("expires_at")
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  site         Site                  @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@map("email_provider_configs")
}

model EmailTemplate {
  id          String          @id @default(cuid())
  siteId      String
  name        String
  subject     String
  html        String          @db.Text
  createdById String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  site        Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdBy   User            @relation(fields: [createdById], references: [id])
  campaigns   EmailCampaign[]

  @@index([siteId])
  @@map("email_templates")
}

enum EmailCampaignStatus {
  DRAFT
  SCHEDULED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

model EmailCampaign {
  id              String              @id @default(cuid())
  siteId          String              @map("site_id")
  templateId      String?             @map("template_id")
  title           String
  subject         String
  content         String              @db.Text
  status          EmailCampaignStatus @default(DRAFT)
  scheduledAt     DateTime?           @map("scheduled_at")
  startedAt       DateTime?           @map("started_at")
  completedAt     DateTime?           @map("completed_at")
  totalRecipients Int                 @default(0)
  totalSent       Int                 @default(0)
  totalOpened     Int                 @default(0)
  totalClicked    Int                 @default(0)
  createdById     String              @map("created_by_id")
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  site            Site                @relation(fields: [siteId], references: [id], onDelete: Cascade)
  template        EmailTemplate?      @relation(fields: [templateId], references: [id])

  createdBy  User             @relation(fields: [createdById], references: [id])
  recipients EmailRecipient[]

  @@index([siteId])
  @@index([status])
  @@map("email_campaigns")
}

enum EmailRecipientStatus {
  PENDING
  SENT
  OPENED
  CLICKED
  BOUNCED
  FAILED
  UNSUBSCRIBED
}

model EmailRecipient {
  id         String               @id @default(cuid())
  campaignId String               @map("campaign_id")
  userId     String?              @map("user_id")
  email      String
  name       String?
  status     EmailRecipientStatus @default(PENDING)
  messageId  String?              @map("message_id")
  sentAt     DateTime?
  openedAt   DateTime?
  clickedAt  DateTime?
  error      String?              @db.Text
  createdAt  DateTime             @default(now())
  campaign   EmailCampaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  user User? @relation(fields: [userId], references: [id])

  @@index([campaignId])
  @@index([status])
  @@map("email_recipients")
}

enum EmailSubscriberStatus {
  ACTIVE
  UNSUBSCRIBED
  BLOCKED
}

model EmailSubscriber {
  id             String                @id @default(cuid())
  siteId         String                @map("site_id")
  userId         String?               @map("user_id")
  email          String
  name           String?
  status         EmailSubscriberStatus @default(ACTIVE)
  subscribedAt   DateTime              @default(now())
  unsubscribedAt DateTime?
  createdAt      DateTime              @default(now())
  site           Site                  @relation(fields: [siteId], references: [id], onDelete: Cascade)
  user           User?                 @relation(fields: [userId], references: [id])

  @@index([siteId])
  @@index([email])
  @@map("email_subscribers")
}

model EmailLog {
  id String @id @default(cuid())

  siteId String

  level String

  message String @db.Text

  metadata Json?

  createdAt DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
}
