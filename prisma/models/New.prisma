model News {
  id          String      @id @default(cuid())
  title       String      @db.VarChar(255)
  slug        String      @unique @db.VarChar(255)
  href        String?     @db.VarChar(500)

  excerpt     String?     @db.Text
  content     String?     @db.Text

  imageSrc    String?     @db.VarChar(1000)
  imageAlt    String?     @db.VarChar(255)

  category    String?     @db.VarChar(100)
  badge       String?     @db.VarChar(100)
  accent      NewsAccent  @default(pink)

  readTime    Int         @default(5)
  views       Int         @default(0)
  comments    Int         @default(0)
  rating      Decimal?    @db.Decimal(2, 1)

  isFeatured  Boolean     @default(false)
  isTrending  Boolean     @default(false)
  status      NewsStatus  @default(PUBLISHED)

  author      String?     @db.VarChar(120)
  publishedAt DateTime?
  tags        String[]

  seoTitle       String?  @db.VarChar(255)
  seoDescription String?  @db.VarChar(300)

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([slug])
  @@index([category])
  @@index([status])
  @@index([isFeatured])
  @@index([isTrending])
  @@index([publishedAt])
  @@index([createdAt])
}

enum NewsAccent {
  pink
  cyan
  orange
  purple
  blue
}

enum NewsStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}
