// =======================
// Enums
// =======================

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ProductType {
  PHYSICAL
  DIGITAL
  SERVICE
}

enum AttributeType {
  TEXT
  NUMBER
  BOOLEAN
  SELECT
  MULTISELECT
  DATE
}

// =======================
// Product
// =======================

model Product {
  id          String        @id @default(cuid())
  siteId      String        @map("site_id")

  name        String
  slug        String

  // content
  shortDescription String?  @map("short_description")
  description     String?

  // classification
  productType ProductType   @default(PHYSICAL) @map("product_type")
  brand       String?
  vendor      String?
  tags        String[]      @default([])

  // lifecycle
  status      ProductStatus @default(DRAFT)
  isVisible   Boolean       @default(true) @map("is_visible")
  publishedAt DateTime?     @map("published_at")

  // SEO
  metaTitle       String?   @map("meta_title")
  metaDescription String?   @map("meta_description")

  // shipping defaults (fallback for variants)
  weight      Decimal?      @db.Decimal(12, 3)
  length      Decimal?      @db.Decimal(12, 3)
  width       Decimal?      @db.Decimal(12, 3)
  height      Decimal?      @db.Decimal(12, 3)

  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  deletedAt   DateTime?     @map("deleted_at")

  // relations
  site         Site                  @relation(fields: [siteId], references: [id], onDelete: Cascade)
  variants     ProductVariant[]
  optionValues ProductOptionValue[]
  images       ProductImage[]
  categoryMap  ProductCategoryMap[]

  // ✅ new: dynamic attributes values (specs)
  attributeValues ProductAttributeValue[]

  @@unique([siteId, slug])
  @@index([siteId])
  @@index([siteId, status])
  @@index([siteId, isVisible])
  @@index([siteId, publishedAt])
  @@map("products")
}

// =======================
// Variant
// =======================

model ProductVariant {
  id             String   @id @default(cuid())
  productId      String   @map("product_id")

  // sku unique within site
  siteId         String   @map("site_id")
  sku            String

  // display
  title          String?
  isActive       Boolean  @default(true) @map("is_active")

  // pricing
  price          Decimal  @db.Decimal(12, 2)
  compareAtPrice Decimal? @db.Decimal(12, 2) @map("compare_at_price")
  cost           Decimal? @db.Decimal(12, 2)

  // inventory
  stockQty       Int      @default(0) @map("stock_qty")
  barcode        String?

  // shipping per variant (override product defaults)
  weight         Decimal? @db.Decimal(12, 3)
  length         Decimal? @db.Decimal(12, 3)
  width          Decimal? @db.Decimal(12, 3)
  height         Decimal? @db.Decimal(12, 3)

  isDefault      Boolean  @default(false) @map("is_default")

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  // relations
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  site           Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  images         ProductImage[]

  // ✅ new: mapping variant -> option values
  optionLinks    ProductVariantOptionValue[]

  // ✅ new: attribute values override at variant level (optional)
  attributeValues ProductAttributeValue[]

  @@index([productId])
  @@index([siteId])
  @@unique([siteId, sku])
  @@map("product_variants")
}

// =======================
// Options (product-level option values)
// =======================

model ProductOptionValue {
  id          String   @id @default(cuid())
  productId   String   @map("product_id")

  optionName  String   @map("option_name")  // ex: Color, Size
  optionValue String   @map("option_value") // ex: Red, XL
  createdAt   DateTime @default(now()) @map("created_at")

  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  // ✅ new: mapping to variants
  variantLinks ProductVariantOptionValue[]

  @@index([productId])
  @@unique([productId, optionName, optionValue])
  @@map("product_option_values")
}

// ✅ new: Variant <-> OptionValue join
model ProductVariantOptionValue {
  variantId     String @map("variant_id")
  optionValueId String @map("option_value_id")

  variant       ProductVariant     @relation(fields: [variantId], references: [id], onDelete: Cascade)
  optionValue   ProductOptionValue @relation(fields: [optionValueId], references: [id], onDelete: Cascade)

  @@id([variantId, optionValueId])
  @@index([optionValueId])
  @@map("product_variant_option_values")
}

// =======================
// Images
// =======================

model ProductImage {
  id        String   @id @default(cuid())
  productId String   @map("product_id")
  variantId String?  @map("variant_id")
  imageUrl  String   @map("image_url")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  product   Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([variantId])
  @@index([productId, sortOrder])
  @@map("product_images")
}

// =======================
// Categories
// =======================

model ProductCategory {
  id        String   @id @default(cuid())
  siteId    String   @map("site_id")
  name      String
  slug      String
  parentId  String?  @map("parent_id")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  parent    ProductCategory? @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  ProductCategory[] @relation("CategoryTree")
  products  ProductCategoryMap[]

  // ✅ new: attributes schema for this category
  attributes ProductAttribute[]

  @@unique([siteId, slug])
  @@index([siteId])
  @@index([parentId])
  @@index([siteId, sortOrder])
  @@map("product_categories")
}

model ProductCategoryMap {
  productId  String @map("product_id")
  categoryId String @map("category_id")

  product    Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId])
  @@map("product_category_map")
}

// =======================
// ✅ Dynamic Attributes (Category schema + Values)
// =======================

model ProductAttribute {
  id          String        @id @default(cuid())
  siteId      String        @map("site_id")
  categoryId  String        @map("category_id")

  code        String        // unique key: power, material...
  name        String        // display: "Công suất", "Chất liệu"
  type        AttributeType
  unit        String?
  isRequired  Boolean       @default(false) @map("is_required")
  sortOrder   Int           @default(0) @map("sort_order")

  category    ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  options     ProductAttributeOption[]
  values      ProductAttributeValue[]

  @@unique([siteId, categoryId, code])
  @@index([siteId, categoryId])
  @@map("product_attributes")
}

model ProductAttributeOption {
  id           String @id @default(cuid())
  attributeId  String @map("attribute_id")

  value        String
  sortOrder    Int    @default(0) @map("sort_order")

  attribute    ProductAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  values       ProductAttributeValue[]

  @@unique([attributeId, value])
  @@index([attributeId])
  @@map("product_attribute_options")
}

model ProductAttributeValue {
  id           String   @id @default(cuid())
  productId    String   @map("product_id")
  variantId    String?  @map("variant_id")
  attributeId  String   @map("attribute_id")

  // store value (choose depending on attribute.type)
  valueText    String?
  valueNumber  Decimal? @db.Decimal(18, 6)
  valueBool    Boolean?
  valueDate    DateTime?
  optionId     String?  @map("option_id") // for SELECT/MULTISELECT (one row per selected option)

  product      Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant      ProductVariant?  @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attribute    ProductAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  option       ProductAttributeOption? @relation(fields: [optionId], references: [id], onDelete: SetNull)

  @@unique([productId, variantId, attributeId, optionId])
  @@index([productId])
  @@index([variantId])
  @@index([attributeId])
  @@map("product_attribute_values")
}
