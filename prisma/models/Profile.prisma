enum ProfileRole {
  ADMIN
  STAFF
  USER
}

enum ProfileStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Profile {
  id          String        @id @default(cuid())
  userId      String        @unique @map("user_id")

  firstName   String?       @map("first_name")
  lastName    String?       @map("last_name")
  username    String?       @unique

  role        ProfileRole   @default(USER)
  status      ProfileStatus @default(ACTIVE)

  email       String?       @map("email")
  backupEmail String?       @map("backup_email")

  phone       String?       @map("phone")
  address     String?       @map("address")

  city        String?       @map("city")
  country     String?       @map("country")

  company     String?       @map("company")
  department  String?       @map("department")
  jobTitle    String?       @map("job_title")
  manager     String?       @map("manager")
  hireDate    DateTime?     @map("hire_date")

  gender      String?       @map("gender")
  locale      String?       @map("locale")
  timezone    String?       @map("timezone")

  dobMonth    String?       @map("dob_month")
  dobDay      Int?          @map("dob_day")
  dobYear     Int?          @map("dob_year")

  twitter     String?       @map("twitter")
  linkedin    String?       @map("linkedin")
  facebook    String?       @map("facebook")
  github      String?       @map("github")
  website     String?       @map("website")

  slogan      String?       @map("slogan")
  bio         String?       @map("bio")

  twoFA       Boolean       @default(false) @map("two_fa")

  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  // ✅ Relation User <-> Profile
  user        User          @relation("UserProfile", fields: [userId], references: [id], onDelete: Cascade)

  // ✅ site membership của profile
  siteId      String?       @map("site_id")
  site        Site?         @relation("SiteProfile", fields: [siteId], references: [id], onDelete: SetNull)

  @@index([siteId], map: "idx_profiles_site_id")
  @@index([firstName])
  @@index([lastName])
  @@index([role])
  @@index([status])
  @@map("profiles")
}
