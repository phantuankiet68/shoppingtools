enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ProductType {
  PHYSICAL
  DIGITAL
  SERVICE
}

model Product {
  id               String        @id @default(cuid())
  siteId           String        @map("site_id")
  categoryId       String        @map("category_id")
  brandId          String?       @map("brand_id")
  name             String
  slug             String
  shortDescription String?       @map("short_description")
  description      String?
  productType      ProductType   @default(PHYSICAL) @map("product_type")
  tags             String[]      @default([])
  status           ProductStatus @default(DRAFT)
  isVisible        Boolean       @default(true) @map("is_visible")
  publishedAt      DateTime?     @map("published_at")
  metaTitle        String?       @map("meta_title")
  metaDescription  String?       @map("meta_description")

  price       Decimal? @map("price") @db.Decimal(12, 2)
  marketPrice Decimal? @map("market_price") @db.Decimal(12, 2)
  savingPrice Decimal? @map("saving_price") @db.Decimal(12, 2)
  productQty  Int      @default(0) @map("product_qty")

  weight    Decimal?  @db.Decimal(12, 3)
  length    Decimal?  @db.Decimal(12, 3)
  width     Decimal?  @db.Decimal(12, 3)
  height    Decimal?  @db.Decimal(12, 3)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  site     Site             @relation(fields: [siteId], references: [id], onDelete: Cascade)
  category ProductCategory  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  brand    ProductBrand?    @relation(fields: [brandId], references: [id], onDelete: SetNull)
  variants ProductVariant[]
  images   ProductImage[]
  reviews  Review[]

  @@unique([siteId, slug])
  @@index([siteId])
  @@index([categoryId])
  @@index([brandId])
  @@index([siteId, status])
  @@index([siteId, isVisible])
  @@index([siteId, publishedAt])
  @@map("products")
}

model ProductBrand {
  id          String    @id @default(cuid())
  siteId      String    @map("site_id")
  name        String
  slug        String
  description String?
  logoUrl     String?   @map("logo_url")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  site        Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  products    Product[]

  @@unique([siteId, slug])
  @@unique([siteId, name])
  @@index([siteId])
  @@map("product_brands")
}

model ProductVariant {
  id                        String                     @id @default(cuid())
  productId                 String                     @map("product_id")
  siteId                    String                     @map("site_id")
  sku                       String
  title                     String?
  isActive                  Boolean                    @default(true) @map("is_active")
  price                     Decimal                    @db.Decimal(12, 2)
  compareAtPrice            Decimal?                   @map("compare_at_price") @db.Decimal(12, 2)
  cost                      Decimal?                   @db.Decimal(12, 2)
  stockQty                  Int                        @default(0) @map("stock_qty")
  barcode                   String?
  weight                    Decimal?                   @db.Decimal(12, 3)
  length                    Decimal?                   @db.Decimal(12, 3)
  width                     Decimal?                   @db.Decimal(12, 3)
  height                    Decimal?                   @db.Decimal(12, 3)
  isDefault                 Boolean                    @default(false) @map("is_default")
  createdAt                 DateTime                   @default(now()) @map("created_at")
  updatedAt                 DateTime                   @updatedAt @map("updated_at")
  deletedAt                 DateTime?                  @map("deleted_at")
  product                   Product                    @relation(fields: [productId], references: [id], onDelete: Cascade)
  site                      Site                       @relation(fields: [siteId], references: [id], onDelete: Cascade)
  images                    ProductImage[]
  stockLevel                StockLevel?
  stockMovements            StockMovement[]
  purchaseOrderLines        PurchaseOrderLine[]
  purchaseOrderReceiptLines PurchaseOrderReceiptLine[]

  @@unique([siteId, sku])
  @@index([productId])
  @@index([siteId])
  @@map("product_variants")
}

model ProductImage {
  id        String          @id @default(cuid())
  productId String          @map("product_id")
  variantId String?         @map("variant_id")
  imageUrl  String          @map("image_url")
  sortOrder Int             @default(0) @map("sort_order")
  createdAt DateTime        @default(now()) @map("created_at")
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([variantId])
  @@index([productId, sortOrder])
  @@map("product_images")
}

model ProductCategory {
  id        String            @id @default(cuid())
  siteId    String            @map("site_id")
  name      String
  slug      String
  parentId  String?           @map("parent_id")
  sortOrder Int               @default(0) @map("sort_order")
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")
  site      Site              @relation(fields: [siteId], references: [id], onDelete: Cascade)
  parent    ProductCategory?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  ProductCategory[] @relation("CategoryTree")
  products  Product[]

  @@unique([siteId, slug])
  @@index([siteId])
  @@index([parentId])
  @@index([siteId, sortOrder])
  @@map("product_categories")
}
