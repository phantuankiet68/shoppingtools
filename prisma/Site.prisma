enum SiteStatus {
  DRAFT
  ACTIVE
  SUSPENDED
}

model Site {
  id                      String                  @id @default(cuid())
  name                    String
  domain                  String                  @unique
  type                    WebsiteType             @default(ecommerce)
  ownerUserId             String                  @map("owner_user_id")
  createdByUserId         String?                 @map("created_by_user_id")
  workspaceId             String?                 @map("workspace_id")
  status                  SiteStatus              @default(DRAFT)
  isPublic                Boolean                 @default(false) @map("is_public")
  publishedAt             DateTime?               @map("published_at")
  themeConfig             Json?                   @map("theme_config")
  seoTitleDefault         String?                 @map("seo_title_default")
  seoDescDefault          String?                 @map("seo_desc_default")
  createdAt               DateTime                @default(now()) @map("created_at")
  updatedAt               DateTime                @updatedAt @map("updated_at")
  deletedAt               DateTime?               @map("deleted_at")
  owner                   User                    @relation("SiteOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  members                 Profile[]               @relation("SiteProfile")
  emailLogs               EmailLog[]
  automationRules         AutomationRule[]
  channelConnections      ChannelConnection[]
  automationEventOutboxes AutomationEventOutbox[]
  automationJobRuns       AutomationJobRun[]
  messageTemplates        MessageTemplate[]
  audiences               Audience[]
  customers               Customer[]
  addresses               Address[]
  menuItems               MenuItem[]
  orders                  Order[]
  orderItems              OrderItem[]
  payments                Payment[]
  fulfillments            Fulfillment[]
  pages                   Page[]
  products                Product[]
  productBrands           ProductBrand[]
  productVariants         ProductVariant[]
  productCategories       ProductCategory[]

  storageIntegration StorageIntegration?
  storageLogs        StorageLog[]

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdBy                 User?                      @relation("SiteCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  stockLevels               StockLevel[]
  stockMovements            StockMovement[]
  purchaseOrders            PurchaseOrder[]
  purchaseOrderLines        PurchaseOrderLine[]
  purchaseOrderReceipts     PurchaseOrderReceipt[]
  purchaseOrderReceiptLines PurchaseOrderReceiptLine[]
  reviews                   Review[]
  systemCredentials         SystemCredential[]

  @@index([ownerUserId])
  @@index([workspaceId])
  @@index([status])
  @@index([isPublic])
  @@index([publishedAt])
  @@index([type])
  @@map("sites")
}
