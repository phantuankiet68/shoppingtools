model TikTokAuthor {
  id String @id @default(cuid())

  userId String

  tiktokOpenId String @unique

  username    String?
  displayName String?
  avatar      String?

  accessToken  String  @db.Text
  refreshToken String? @db.Text

  tokenExpiresAt DateTime?

  autoPublish Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  tiktokPosts TikTokPost[]

  @@index([userId])
  @@map("tiktok_authors")
}

model TikTokPost {
  id String @id @default(cuid())

  userId String

  tiktokAuthorId String?

  title String

  description String @db.Text

  hashtags String? @db.Text

  seoKeywords String? @db.Text

  href String?

  cta String?

  video String

  thumbnail String?

  duration Int?

  status TikTokPostStatus @default(DRAFT)

  publishAt   DateTime?
  publishedAt DateTime?

  tiktokPublishId String?

  tiktokVideoId String?

  retryCount Int @default(0)

  videoDeletedAt DateTime?

  errorMessage String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  tiktokAuthor TikTokAuthor? @relation(fields: [tiktokAuthorId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([publishAt])
  @@index([tiktokAuthorId])
  @@map("tiktok_posts")
}

enum TikTokPostStatus {
  DRAFT
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
}
